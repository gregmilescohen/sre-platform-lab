# OpenCode uses BigPickle by default (free, no API key required).
# Run `opencode auth login` inside the sre-agent container to authenticate,
# or set OPENCODE_API_KEY if OpenCode supports it for your version.
# See: https://opencode.ai/docs/cli/

# Override to use a different OpenCode-compatible model:
# OPENCODE_MODEL=opencode/big-pickle

# PulseBoard service URLs (defaults work with docker-compose)
PUBSUB_PROJECT_ID=pulseboard
PUBSUB_TOPIC_ID=pulseboard-events
PUBSUB_SUBSCRIPTION_ID=pulseboard-events-sub
DATABASE_URL=postgresql://pulseboard:pulseboard@postgres:5432/pulseboard
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085

# sre-agent service URLs (used by MCP servers and Python tools)
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://grafana:3000
PROMETHEUS_URL=http://prometheus:9090
